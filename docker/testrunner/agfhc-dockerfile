ARG BASE_IMAGE=registry.access.redhat.com/ubi9/ubi:9.8
FROM ${BASE_IMAGE}

LABEL maintainer="AMD Inc"
LABEL OS="registry.access.redhat.com/ubi9/ubi:9.8"

ARG AGFHC_VERSION=1.32.0
ARG ROCM_VERSION=7.2.1
ARG RADEON_REPO_URL=https://repo.radeon.com
# Set to full TheRock tarball URL to skip repo.radeon.com and install from tarball.
# Leave empty to use the old dnf-based install path.
ARG ROCM_TARBALL_URL=""
# Full URL to the RVS pre-built tarball.
# Leave empty to install rocm-validation-suite via dnf (old path).
ARG RVS_TARBALL_URL=""

ADD install-rocm-tarball.sh /usr/local/bin/install-rocm-tarball.sh
ADD install-rvs-tarball.sh /usr/local/bin/install-rvs-tarball.sh
RUN chmod +x /usr/local/bin/install-rocm-tarball.sh /usr/local/bin/install-rvs-tarball.sh

# Install ROCm libs and RVS (same two-path logic as Dockerfile).
RUN dnf clean all && \
    if [ -n "${ROCM_TARBALL_URL}" ] && [ -n "${RVS_TARBALL_URL}" ]; then \
        dnf install -y wget tar gzip pciutils && \
        /usr/local/bin/install-rocm-tarball.sh "${ROCM_VERSION}" "${ROCM_TARBALL_URL}" --profile testrunner && \
        /usr/local/bin/install-rvs-tarball.sh "${RVS_TARBALL_URL}"; \
    else \
        dnf install -y https://dl.fedoraproject.org/pub/epel/epel-release-latest-9.noarch.rpm && \
        echo "[ROCm-${ROCM_VERSION}]" > /etc/yum.repos.d/rocm.repo && \
        echo "name=ROCm${ROCM_VERSION}" >> /etc/yum.repos.d/rocm.repo && \
        echo "baseurl=${RADEON_REPO_URL}/rocm/rhel9/${ROCM_VERSION}/main" >> /etc/yum.repos.d/rocm.repo && \
        echo "enabled=1" >> /etc/yum.repos.d/rocm.repo && \
        echo "priority=50" >> /etc/yum.repos.d/rocm.repo && \
        echo "gpgcheck=1" >> /etc/yum.repos.d/rocm.repo && \
        echo "gpgkey=${RADEON_REPO_URL}/rocm/rocm.gpg.key" >> /etc/yum.repos.d/rocm.repo && \
        dnf update -y && \
        dnf install -y rocrand rocm-validation-suite && \
        ln /usr/lib64/libdrm_amdgpu.so.1 /usr/lib64/libdrm_amdgpu.so && \
        dnf config-manager --add-repo=https://mirror.stream.centos.org/9-stream/BaseOS/x86_64/os/ && \
        dnf config-manager --add-repo=https://mirror.stream.centos.org/9-stream/AppStream/x86_64/os/ && \
        rpm --import https://www.centos.org/keys/RPM-GPG-KEY-CentOS-Official && \
        dnf install -y dkms && \
        find /opt/rocm/share/rocm-validation-suite/conf -name '*level_1*' -type f \
            -exec sed -i '/^[[:space:]]*package:/d; /^[[:space:]]*debpackagelist:/d; s/^[[:space:]]*rpmpackagelist:.*/  rpmpackagelist: rocm-core rocminfo comgr rocblas rocrand hsa-rocr hip-runtime-amd/' {} \; ; \
    fi && \
    rm -rf /var/cache/yum /var/cache/dnf && \
    dnf clean all

# Security patch for multiple CVEs (both paths)
RUN dnf update -y libarchive libxml2 pam python3-requests glibc && \
    rm -rf /var/cache/yum /var/cache/dnf && \
    dnf clean all

# Install AGFHC
WORKDIR /agfhc

RUN dnf install -y tar bzip2 python3-pyyaml python3-psutil wget cpio numactl-libs && \
    if [ -z "${ROCM_TARBALL_URL}" ]; then dnf install -y rocm-smi-lib; fi && \
    wget https://atlartifactory.amd.com:8443/artifactory/HW-AGFHCRelease-REL-LOCAL/${AGFHC_VERSION}/mi300/agfhc-mi300_${AGFHC_VERSION}_rhel9.tar.bz2 && \
    tar -xvjf agfhc-mi300_${AGFHC_VERSION}_rhel9.tar.bz2 && \
    rm -rf agfhc-mi300_${AGFHC_VERSION}_rhel9.tar.bz2 && \
    ROCM_MAJOR_MINOR=$(echo "${ROCM_VERSION}" | grep -oP '^\d+\.\d+') && \
    ./install --rocm-ver "${ROCM_MAJOR_MINOR}" --no-sign-check && \
    if [ -z "${ROCM_TARBALL_URL}" ]; then ln /usr/lib64/libdrm_amdgpu.so.1 /usr/lib64/libdrm_amdgpu.so; fi && \
    rm -rf *.tar.bz2 *.rpm rocm* && \
    rm -rf /var/cache/yum /var/cache/dnf && \
    dnf clean all && \
    if [ -n "${ROCM_TARBALL_URL}" ]; then \
        mkdir -p /opt/rocm/.info && \
        echo "${ROCM_VERSION}" | grep -oP '^\d+\.\d+\.\d+' > /opt/rocm/.info/version; \
    fi

WORKDIR /

ADD amd-test-runner /amd-test-runner
ADD LICENSE /licenses/LICENSE
RUN chmod +x /amd-test-runner

ENV LD_LIBRARY_PATH=/opt/rocm/lib:/opt/rocm/lib/rvs:/opt/rocm/lib/rocm_sysdeps/lib:/opt/rocm/lib/llvm/lib:$LD_LIBRARY_PATH

LABEL name="amd-device-test-runner" \
    maintainer="yan.sun3@amd.com,udaybhaskar.biluri@amd.com,shrey.ajmera@amd.com" \
    vendor="Advanced Micro Devices, Inc." \
    version="v1.4.1" \
    release="v1.4.1" \
    summary="AMD Device Test Runner performs troubleshooting and benchmarking tests on AMD GPUs across Kubernetes clusters." \
    description="AMD Device Test Runner ensures that GPUs are functioning correctly and efficiently by running a series of diagnostic tests and performance benchmarks. It helps identify issues, optimize GPU performance, and validate the readiness of GPU resources by running Rocm Validation Suite (RVS) and AMD GPU Field Health Check (AGFHC) tests."

ENTRYPOINT ["/amd-test-runner"]
